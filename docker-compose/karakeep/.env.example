# =============================================================================
# KARAKEEP ENVIRONMENT VARIABLES - EXAMPLE FILE
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# Domain
DOMAIN_NAME=YOUR_DOMAIN

# Timezone
TZ=Europe/Lisbon

# =============================================================================
# KARAKEEP AUTH
# =============================================================================
# Generate with: openssl rand -base64 36
NEXTAUTH_SECRET=replace_with_random_secret

# Must match your public URL exactly
NEXTAUTH_URL=https://karakeep.YOUR_DOMAIN

# =============================================================================
# MEILISEARCH
# =============================================================================
# Generate with: openssl rand -base64 36
MEILI_MASTER_KEY=replace_with_random_secret

# =============================================================================
# CHROME (BROWSERLESS)
# =============================================================================
# Generate with: openssl rand -hex 16
CHROME_TOKEN=replace_with_random_token

# =============================================================================
# AI TAGGING (disabled by default — enable later)
# =============================================================================
# Preferred: OpenAI GPT-4.1
# See docs/services/karakeep.md → AI Tagging for full enable procedure
# OPENAI_API_KEY=sk-...
# INFERENCE_TEXT_MODEL=gpt-4.1
# INFERENCE_IMAGE_MODEL=gpt-4.1
# INFERENCE_CONTEXT_LENGTH=4096
# INFERENCE_ENABLE_AUTO_SUMMARIZATION=true

# Authelia OIDC — single sign-on (configured in Phase 4)
# OAUTH_WELLKNOWN_URL=https://auth.<DOMAIN_NAME>/.well-known/openid-configuration
# OAUTH_CLIENT_ID=karakeep
# OAUTH_CLIENT_SECRET=replace_with_client_secret
# OAUTH_PROVIDER_NAME=Authelia
# OAUTH_AUTO_REDIRECT=true
# DISABLE_PASSWORD_AUTH=true
