# =============================================================================
# PI-HOLE ENVIRONMENT VARIABLES - EXAMPLE FILE
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# =============================================================================
# BASIC SETTINGS
# =============================================================================
# Timezone for Pi-hole logs and interface
TZ=Europe/Lisbon

# =============================================================================
# PI-HOLE WEB INTERFACE
# =============================================================================
# Password for Pi-hole admin interface (change this!)
PIHOLE_PASSWORD=your_secure_pihole_password_here

# =============================================================================
# TRAEFIK INTEGRATION (if using)
# =============================================================================
# Credentials for Traefik dashboard access (if using authentication)
# Generate with: htpasswd -nbB admin yourpassword
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$2y$$10$$example_hash_replace_with_real

# =============================================================================
# DOMAIN CONFIGURATION (if using custom domains)
# =============================================================================
# Your domain name for local services
DOMAIN_NAME=example.local

# =============================================================================
# NETWORK SETTINGS
# =============================================================================
# Your local network subnet (adjust to match your LAN)
LOCAL_SUBNET=<YOUR_LAN_SUBNET>

# Pi-hole host IP on your LAN (the physical machine running Docker)
PIHOLE_HOST_IP=<PIHOLE_HOST_IP>

# Your router's IP address (gateway)
ROUTER_IP=<ROUTER_IP>

# DHCP range start and end (if using Pi-hole DHCP)
DHCP_START=<DHCP_RANGE_START>
DHCP_END=<DHCP_RANGE_END>
