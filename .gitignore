# =============================================================================
# HOMELAB GITIGNORE
# =============================================================================

# =============================================================================
# RUNTIME DATA — docker/ is entirely host-generated, never committed
# =============================================================================
docker/

# =============================================================================
# SENSITIVE CREDENTIALS & SECRETS
# =============================================================================

# Environment files with secrets
.env
.env.local
.env.production
.env.staging
.env.development
*.env
!*.env.example

# Cloudflare API token
**/cf-token
**/cf-token.example
!**/cf-token.example

# =============================================================================
# DOCKER & CONTAINERIZATION
# =============================================================================

# Container logs
**/*container*.log
**/docker-compose.override.yml

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================

*.log
**/logs/
**/log/
**/*.log.*
*.tmp
*.temp
**/tmp/
**/temp/
*.bak
*.backup
*.old
**/backups/
**/backup/
**/*.tar.gz
**/*.zip

# =============================================================================
# SYSTEM & OS FILES
# =============================================================================

.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# DEVELOPMENT & EDITOR FILES
# =============================================================================

.vscode/
.idea/
*.swp
*.swo
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# CUSTOM ADDITIONS
# =============================================================================

# Sure .env (no .env.example exists for this service)
docker-compose/sure/.env

# Claude Code local settings (machine-specific)
.claude/settings.local.json
